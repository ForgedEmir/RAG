# =====================================================
# HELMo Oracle — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# =====================================================

# === LLM Principal (Groq — gratuit) ===
# Creer une cle sur https://console.groq.com
LLM_API_KEY=gsk_VOTRE_CLE_GROQ
# Legacy (optionnel) si vous gardez une ancienne config
OPENAI_API_KEY=
# Optionnel pour HyDE/OpenRouter
OPENROUTER_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# === LLM Fallback (meme cle Groq, modele different) ===
FALLBACK_API_KEY=gsk_VOTRE_CLE_GROQ
FALLBACK_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# === Qdrant — Mode Cloud (recommande) ===
# Creer un cluster gratuit sur https://cloud.qdrant.io
# Laisser vide = Qdrant local (fichiers dans src/ingestion/qdrant_db/)
QDRANT_URL=
QDRANT_API_KEY=

# === Supabase (Auth + Sessions + Monitoring) ===
# Creer un projet sur https://supabase.com
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# === Monitoring — cle d'acces au dashboard /monitoring ===
# Choisis n'importe quelle valeur secrete
MONITORING_KEY=CHANGE_THIS_SECRET_KEY

# === Securite — Lakera Guard (optionnel) ===
# Creer un compte sur https://platform.lakera.ai
LAKERA_API_KEY=
LAKERA_PROJECT_ID=
SECURITY_VALIDATOR=rules

# === Observabilite LLM — Langfuse (optionnel) ===
# Creer un compte sur https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Redis (production multi-workers) ===
# Laisser vide = memoire locale (ok en dev, pas en prod avec plusieurs workers)
# Format : redis://localhost:6379 ou redis://user:pass@host:6379/0
REDIS_URL=

# === Concurrence backend (production) ===
# Profil recommandé pour ~15 utilisateurs concurrents
APP_ENV=production
ENV=production
WEB_CONCURRENCY=2
BACKGROUND_MAX_WORKERS=16
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=10

# === Sentry (optionnel) ===
SENTRY_DSN=

# === CORS — origines autorisees ===
# En dev : laisser vide. En prod : mettre le domaine Coolify
ALLOWED_ORIGINS=

# === Profil de performance (important) ===
# balanced = recommande (qualite + vitesse)
# fast     = latence minimale
# quality  = qualite maximale (plus lent)
RAG_PROFILE=balanced

# Legacy fast switch (si true, force le mode fast)
RAG_FAST_MODE=false

# === Parser de documents ===
# "unstructured" (recommande) ou "custom"
PARSER=unstructured

# === LlamaParse pour les PDFs (optionnel) ===
# Creer une cle sur https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=

# === Embeddings ===
# Default rapide + multilingue + ONNX (sans torch)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Option qualite max (plus lent): intfloat/multilingual-e5-large

# Dimension Qdrant (optionnel)
# Si vide: detectee automatiquement depuis EMBEDDING_MODEL
QDRANT_VECTOR_SIZE=

# Si true: recree automatiquement la collection lore en cas de mismatch de dimension
QDRANT_AUTO_RECREATE_ON_DIM_MISMATCH=true

# === Reranker cross-encoder (optionnel) ===
RERANKER_ENABLED=true
RERANK_SIMPLE_QUERIES=false
# Option rapide: Xenova/ms-marco-MiniLM-L-6-v2 (plus rapide, qualite FR a valider)
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
SMART_RERANK_ENABLED=true
SMART_RERANK_TOP1_MIN=0.014
SMART_RERANK_GAP_MIN=0.01
RERANKER_MAX_INPUT=4
RERANKER_TOP_N=6

# === Parametres RAG ===
CONVERSATION_DEPTH=5
SEARCH_CACHE_TTL=300
SEARCH_CACHE_SIZE=100
REFORMULATION_ENABLED=true
QUERY_EXPANSION_ENABLED=false
HYDE_ENABLED=true
HYDE_TIMEOUT_SECONDS=3.5
HYDE_API_KEY=
HYDE_API_URL=https://openrouter.ai/api/v1/chat/completions

# Reglages retrieval (sweet spot)
SEARCH_SIMPLE_CANDIDATES=5
SEARCH_COMPLEX_CANDIDATES=14
SEARCH_FINAL_TOP_N=4
MIN_VECTOR_BEFORE_BM25=3
# 0 = desactive. Mets 10 pour couper les reponses trop longues.
MAX_RESPONSE_SECONDS=0

# Startup
STARTUP_INDEX_ENABLED=true
STARTUP_WARMUP_ENABLED=true
WATCHDOG_ENABLED=true

# === Speech-to-Text (optionnel) ===
STT_API_KEY=
STT_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL=whisper-large-v3

# === Memoire long-terme utilisateur ===
SUMMARY_UPDATE_INTERVAL=5
TRACKING_ENABLED=true

# === Memoire vectorielle selective (optionnel) ===
VECTOR_MEMORY_ENABLED=false
MAX_USER_MEMORIES=500

# === Ingestion LLM enrichments (impact surtout l'indexation, pas la reponse) ===
INGESTION_LORE_CLASSIFIER_ENABLED=false
INGESTION_CONTEXTUAL_ENRICHMENT_ENABLED=true
