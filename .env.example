# =====================================================
# HELMo Oracle — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# =====================================================

# === LLM Principal (Groq — gratuit) ===
# Creer une cle sur https://console.groq.com
OPENAI_API_KEY=gsk_VOTRE_CLE_GROQ
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# === LLM Fallback (meme cle Groq, modele different) ===
FALLBACK_API_KEY=gsk_VOTRE_CLE_GROQ
FALLBACK_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# === Qdrant — Mode Cloud (recommande) ===
# Creer un cluster gratuit sur https://cloud.qdrant.io
# Laisser vide = Qdrant local (fichiers dans src/ingestion/qdrant_db/)
QDRANT_URL=
QDRANT_API_KEY=

# === Supabase (Auth + Sessions + Monitoring) ===
# Creer un projet sur https://supabase.com
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# === Monitoring — cle d'acces au dashboard /monitoring ===
# Choisis n'importe quelle valeur secrete
MONITORING_KEY=CHANGE_THIS_SECRET_KEY

# === Securite — Lakera Guard (optionnel) ===
# Creer un compte sur https://platform.lakera.ai
LAKERA_API_KEY=
LAKERA_PROJECT_ID=
SECURITY_VALIDATOR=rules

# === Observabilite LLM — Langfuse (optionnel) ===
# Creer un compte sur https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Redis (production multi-workers) ===
# Laisser vide = memoire locale (ok en dev, pas en prod avec plusieurs workers)
# Format : redis://localhost:6379 ou redis://user:pass@host:6379/0
REDIS_URL=

# === Sentry (optionnel) ===
SENTRY_DSN=

# === CORS — origines autorisees ===
# En dev : laisser vide. En prod : mettre le domaine Coolify
ALLOWED_ORIGINS=

# === Parser de documents ===
# "unstructured" (recommande) ou "custom"
PARSER=unstructured

# === LlamaParse pour les PDFs (optionnel) ===
# Creer une cle sur https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=

# === Embeddings ===
EMBEDDING_MODEL=BAAI/bge-m3

# === Reranker cross-encoder (optionnel) ===
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base

# === Parametres RAG ===
CONVERSATION_DEPTH=5
SEARCH_CACHE_TTL=300
SEARCH_CACHE_SIZE=100
REFORMULATION_ENABLED=true

# === Memoire long-terme utilisateur ===
SUMMARY_UPDATE_INTERVAL=5

# === Memoire vectorielle selective (optionnel) ===
VECTOR_MEMORY_ENABLED=false
MAX_USER_MEMORIES=500

# === Query expansion (optionnel) ===
QUERY_EXPANSION_ENABLED=false
