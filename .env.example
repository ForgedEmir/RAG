# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Monitoring ────────────────────────────────────────────────────────────────
# CRITICAL: Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
MONITORING_KEY=CHANGE_ME_use_secrets_token_urlsafe_32

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8000
ENV=development
APP_ENV=development
PORT=8000

# ── Auth ──────────────────────────────────────────────────────────────────────
ALLOW_GUEST_MODE=false
ALLOW_GUEST_MODE_IN_PROD=false
ALLOW_LOCAL_GUEST_HEADER=true

# ── Enterprise auth ───────────────────────────────────────────────────────────
# Lock this instance to one email domain (e.g. acme.com). Leave empty to allow all.
ALLOWED_EMAIL_DOMAIN=
# Comma-separated emails that have admin access to /api/admin/users
ADMIN_EMAILS=
# Frontend: show "Sign up" toggle on login page
VITE_ALLOW_SELF_REGISTER=false
# Frontend: show Microsoft OAuth button (configure Azure provider in Supabase dashboard)
VITE_MICROSOFT_AUTH_ENABLED=false

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── Langfuse (optionnel) ──────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Sentry (optionnel) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Lakera Guard (optionnel) ──────────────────────────────────────────────────
LAKERA_API_KEY=
