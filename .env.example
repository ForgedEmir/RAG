# =====================================================
# Oracle LoreKeeper — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# =====================================================

# === LLM Principal (Groq — gratuit) ===
# Créer une clé sur https://console.groq.com
OPENAI_API_KEY=gsk_VOTRE_CLE_GROQ
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# === LLM Fallback (même clé Groq, modèle différent) ===
FALLBACK_API_KEY=gsk_VOTRE_CLE_GROQ
FALLBACK_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# === Qdrant — Mode Cloud (optionnel, sinon stockage local automatique) ===
# Créer un cluster gratuit sur https://cloud.qdrant.io
# Laisser vide = Qdrant tourne en local via Docker (voir docker-compose.yml)
QDRANT_URL=
QDRANT_API_KEY=

# === Parser de documents ===
# "unstructured" (recommandé) ou "custom"
PARSER=unstructured

# === LlamaParse pour les PDFs (optionnel) ===
# Créer une clé sur https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=

# === Sécurité — Lakera Guard (optionnel) ===
# Créer un compte sur https://platform.lakera.ai
LAKERA_API_KEY=
LAKERA_PROJECT_ID=
SECURITY_VALIDATOR=false

# === Monitoring — Supabase (optionnel) ===
# Créer un projet sur https://supabase.com
SUPABASE_URL=
SUPABASE_KEY=

# === Monitoring — clé d'accès au dashboard /monitoring ===
# Choisis n'importe quelle valeur secrète
MONITORING_KEY=changeme

# === Sentry (optionnel) ===
SENTRY_DSN=

# === CORS — origines autorisées (prod uniquement) ===
# Laisser vide = tout autorisé (ok en local)
ALLOWED_ORIGINS=

# === Observabilité LLM — Langfuse (optionnel) ===
# Créer un compte sur https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Redis (production multi-workers) ===
# Laisser vide = mémoire locale (ok en dev, inutile avec plusieurs workers Gunicorn)
# Format : redis://localhost:6379 ou rediss://user:pass@host:6380 (TLS)
REDIS_URL=

# === Embeddings ===
# Modèle HuggingFace pour les vecteurs (défaut recommandé : BAAI/bge-m3)
EMBEDDING_MODEL=BAAI/bge-m3

# === Reranker cross-encoder (optionnel) ===
# Mettre RERANKER_ENABLED=false pour désactiver (gain de vitesse sur CPU lent)
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === Paramètres RAG ===
# Nombre d'échanges injectés dans le contexte conversationnel (défaut : 5)
CONVERSATION_DEPTH=5
# Taille max des fichiers uploadés en Ko (défaut : 500)
MAX_UPLOAD_SIZE_KB=500

# === Mémoire long-terme utilisateur ===
# Fréquence de mise à jour du résumé (toutes les N interactions, défaut : 5)
SUMMARY_UPDATE_INTERVAL=5

# === Cache de recherche ===
# Durée de vie des résultats en cache (secondes, défaut : 300 = 5 min)
SEARCH_CACHE_TTL=300
# Nombre max d'entrées dans le cache (défaut : 100)
SEARCH_CACHE_SIZE=100

# === Mémoire vectorielle sélective ===
# Stocke les échanges importants dans Qdrant pour une récupération sémantique précise
# Nécessite Qdrant Cloud (QDRANT_URL + QDRANT_API_KEY) ou Qdrant local
VECTOR_MEMORY_ENABLED=false
# Nombre max de souvenirs vectoriels par utilisateur (les plus anciens sont supprimés au-delà)
MAX_USER_MEMORIES=500

# === Query expansion ===
# Génère 2 variantes LLM pour les requêtes complexes (coût : 1 appel LLM supplémentaire)
# Activé seulement pour les requêtes complexes détectées par le router
QUERY_EXPANSION_ENABLED=false
