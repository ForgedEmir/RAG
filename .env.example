# Oracle LoreKeeper environment template
# Copy this file to .env and fill the secret values.

# App
APP_ENV=development
ENV=development
PORT=8000
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Runtime profile
RAG_PROFILE=balanced
RAG_FAST_MODE=false

# Primary LLM
LLM_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_MODEL=llama3.1-8b

# Fallback LLM
FALLBACK_API_KEY=
FALLBACK_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_MODEL=llama-3.3-70b-versatile

# Reformulation model (optional)
REFORMULATION_API_KEY=
REFORMULATION_BASE_URL=
REFORMULATION_MODEL=

# Speech-to-text (optional)
STT_API_KEY=
STT_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL=whisper-large-v3
MAX_STT_UPLOAD_MB=10

# Vector database / embeddings
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_VECTOR_SIZE=
QDRANT_AUTO_RECREATE_ON_DIM_MISMATCH=true
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_KEY=

# Auth / monitoring
MONITORING_KEY=
ALLOW_GUEST_MODE=true
ALLOW_LOCAL_GUEST_HEADER=true
JWT_CACHE_TTL_SECONDS=60
JWT_CACHE_MAX_SIZE=512
MAX_UPLOAD_SIZE_KB=500

# Redis
REDIS_URL=redis://localhost:6379

# Ingestion
PARSER=unstructured
LLAMA_CLOUD_API_KEY=
INGESTION_LORE_CLASSIFIER_ENABLED=false
INGESTION_CONTEXTUAL_ENRICHMENT_ENABLED=true
CHUNK_DEDUP_ENABLED=true
LATE_CHUNKING_ENABLED=true
LATE_CHUNKING_WINDOW=3
STARTUP_INDEX_ENABLED=true
STARTUP_WARMUP_ENABLED=true
WATCHDOG_ENABLED=true

# Retrieval / generation tuning
REFORMULATION_ENABLED=true
QUERY_EXPANSION_ENABLED=false
HYDE_ENABLED=true
HYDE_TIMEOUT_SECONDS=3.5
HYDE_SCORE_THRESHOLD=0.005
RERANKER_ENABLED=true
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANKER_MAX_INPUT=4
RERANKER_TOP_N=6
RERANK_SIMPLE_QUERIES=false
SMART_RERANK_ENABLED=true
SMART_RERANK_TOP1_MIN=0.014
SMART_RERANK_GAP_MIN=0.01
SEARCH_SIMPLE_CANDIDATES=5
SEARCH_COMPLEX_CANDIDATES=14
SEARCH_FINAL_TOP_N=4
MIN_VECTOR_BEFORE_BM25=3
SEARCH_CACHE_TTL=300
SEARCH_CACHE_SIZE=100
SCACHE_MATRIX_REFRESH=120
CONVERSATION_DEPTH=5
MAX_RESPONSE_SECONDS=10
BACKGROUND_MAX_WORKERS=16
MAX_USER_LOCKS=5000

# User memory
VECTOR_MEMORY_ENABLED=false
MAX_USER_MEMORIES=500
SUMMARY_UPDATE_INTERVAL=5
SUMMARY_IMPORTANCE_MIN_LEN=80

# Security
SECURITY_VALIDATOR=true
LAKERA_API_KEY=
LAKERA_PROJECT_ID=
LAKERA_MODE=enforce
LAKERA_CACHE_TTL=60
LAKERA_THRESHOLD=0.8

# Observability
TRACKING_ENABLED=true
TRACE_CONTEXT_TTL_SECONDS=7200
TRACE_CONTEXT_MAX_SIZE=5000
FEEDBACK_EVENTS_BUFFER_SIZE=500
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# Web server
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=10
LOG_BUFFER_SIZE=1000

# MCP
MCP_TRANSPORT=stdio
MCP_PORT=8001
MCP_FAST_MODE=true
MCP_FILE_ROOT=data/sample
