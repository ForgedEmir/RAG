# ===========================================
# Oracle LoreKeeper - Configuration
# ===========================================
# Copie ce fichier en .env et remplis les valeurs.
# cp .env.exemple .env

# === LLM (Intelligence Artificielle) ===
# Cle API pour le provider LLM (DeepSeek, OpenAI, Groq, etc.)
OPENAI_API_KEY=""

# URL de base du provider LLM (changeable sans toucher au code)
# DeepSeek : https://api.deepseek.com
# Groq     : https://api.groq.com/openai/v1
# OpenAI   : https://api.openai.com/v1
# Ollama   : http://localhost:11434/v1
LLM_BASE_URL="https://api.deepseek.com"

# Modele LLM a utiliser
# DeepSeek : deepseek-chat
# Groq     : llama-3.3-70b-versatile
# OpenAI   : gpt-4o-mini
# Ollama   : llama3.2
LLM_MODEL="deepseek-chat"

# === Embeddings ===
# Modele FastEmbed pour la vectorisation des textes (gratuit, local)
# Voir le HuggingFace MTEB Leaderboard pour d'autres modeles
EMBEDDING_MODEL="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"

# === Parser ===
# Methode d'extraction de texte depuis les fichiers
# unstructured : Unstructured.io (recommande, gere mieux les fichiers corrompus)
# custom       : Parser maison (fallback)
PARSER="unstructured"

# === TTS (Text-to-Speech) - Phase future ===
# none  : Pas de synthese vocale
# piper : Piper TTS (offline, open-source)
# edge  : Edge TTS (online, gratuit Microsoft)
TTS_ENGINE="none"
