        <mxCell id="f_search" value="Recherche Sémantique&#xa;search.py&#xa;&#xa;① Vectorise la question reformulée&#xa;   (FastEmbed · 384d)&#xa;② similarity_search(k=5)&#xa;   dans Qdrant Cloud&#xa;③ Retourne top 5 passages&#xa;   + noms des fichiers sources" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
