          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="f_gen" value="Génération en Streaming&#xa;generator.py&#xa;&#xa;LangChain ChatOpenAI (streaming=True)&#xa;&#xa;SystemMessage :&#xa;&quot;Tu es un assistant spécialisé&#xa;dans le lore d'Aethelgard.&#xa;Réponds UNIQUEMENT avec&#xa;le contexte fourni.&quot;&#xa;&#xa;HumanMessage : question reformulée&#xa;Température : 0.2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
