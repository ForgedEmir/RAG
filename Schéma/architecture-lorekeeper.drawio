        <mxCell id="f_rewrite" value="Query Rewriting&#xa;generator.py&#xa;&#xa;reformuler_question()&#xa;&#xa;&quot;Il fait quelle taille ?&quot;&#xa;→ &quot;Quelle est la taille de&#xa;Lucas le Tranchant ?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
